# Meta / Instagram Graph API
# Use a long-lived access token with instagram_content_publish permission.
IG_ACCESS_TOKEN=
IG_USER_ID=
GRAPH_API_VERSION=v25.0

# Optional: only needed if you want AI-generated captions instead of the built-in generator.
# The app can run without this.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: public HTTPS URL where generated images are reachable by Meta.
# Example if deployed: https://your-domain.com/static/generated
# For local-only preview, leave blank. Meta cannot fetch http://127.0.0.1 files.
PUBLIC_MEDIA_BASE_URL=

# Flask
FLASK_SECRET_KEY=change-this-local-secret
APP_HOST=127.0.0.1
APP_PORT=8508
